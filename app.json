{
  "expo": {
    "name": "Gambot",
    "slug": "gambot-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gambot",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2e6155"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gambot.mobile",
      "buildNumber": "1",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Gambot needs access to your camera to take photos and videos to share in chats.",
        "NSPhotoLibraryUsageDescription": "Gambot needs access to your photo library to share images and media files in chats.",
        "LSApplicationQueriesSchemes": [
          "whatsapp",
          "tel",
          "mailto"
        ]
      }
    },
    "android": {
      "package": "com.gambot.mobile",
      "versionCode": 5,
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/adaptive-foreground.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2e6155"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Gambot to access your photos to share media in chats.",
          "cameraPermission": "Allow Gambot to access your camera to take photos and videos."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef6c2932-16ab-410d-8e34-b2926e4b92e7"
      }
    },
    "owner": "segas_nir"
  }
}
