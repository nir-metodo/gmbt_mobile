{
  "expo": {
    "name": "Gambot",
    "slug": "gambot-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gambot",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2e6155"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gambot.mobile",
      "buildNumber": "1",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Gambot needs access to your camera to take photos and videos to share in chats.",
        "NSPhotoLibraryUsageDescription": "Gambot needs access to your photo library to share images and media files in chats.",
        "LSApplicationQueriesSchemes": ["whatsapp", "tel", "mailto"]
      }
    },
    "android": {
      "package": "com.gambot.mobile",
      "versionCode": 1,
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "backgroundColor": "#2e6155",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2e6155"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Gambot to access your photos to share media in chats.",
          "cameraPermission": "Allow Gambot to access your camera to take photos and videos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "gambot-mobile"
      }
    }
  }
}
